# ==============================================================================
#
# orb.targets -- project target and solution registry.
# Format reference: source/tools/build_tool/build_tool_03_registry.c
#
# ==============================================================================
# 01_BASE
# ==============================================================================

target base

    type        static
    root        source/base
    folder      01_BASE
    unit        base.c

# ==============================================================================
# 02_ENGINE
# ==============================================================================

target sys

    type        static
    root        source/engine/sys
    folder      02_ENGINE
    unit        sys.c
    flag        host_only

target ref

    type        static
    root        source/engine/ref
    folder      02_ENGINE
    unit        ref.c
    flag        host_only

target mod

    type        static
    root        source/engine/mod
    folder      02_ENGINE
    unit        mod.c
    dep         sys
    flag        host_only

target app

    type        static
    root        source/engine/app
    folder      02_ENGINE
    unit        app.c
    dep         sys
    flag        host_only

target core

    type        static
    root        source/engine/core
    folder      02_ENGINE
    unit        core.c
    dep         sys ref
    flag        reflect host_only

target net

	type        static
    root        source/engine/net
    folder      02_ENGINE
    unit        net.c
	
# ==============================================================================
# 03_RUNTIME
# ==============================================================================

target run

    type        static
    root        source/runtime
    folder      03_RUNTIME
    unit        runtime.c
    dep         mod sys ref core app

# ==============================================================================
# 03_RUNTIME_SERVICE
# ==============================================================================

target rhi

    type        static
    root        source/runtime_service/rhi
    folder      03_RUNTIME/SERVICE
    unit        rhi.c
    dep         app

target jobs

    type        static
    root        source/runtime_service/jobs
    folder      03_RUNTIME/SERVICE
    unit        jobs.c

# ==============================================================================
# 03_RUNTIME_MODULES
# ==============================================================================

target example

    type        dynamic
    root        source/runtime_modules/example
    folder      03_RUNTIME/MODULES
    unit        example.c

target render

    type        dynamic
    root        source/runtime_modules/render
    folder      03_RUNTIME/MODULES
    unit        render.c

target audio

    type        dynamic
    root        source/runtime_modules/audio
    folder      03_RUNTIME/MODULES
    unit        audio.c

target physics

    type        dynamic
    root        source/runtime_modules/physics
    folder      03_RUNTIME/MODULES
    unit        physics.c

# ==============================================================================
# 04_GAME
# ==============================================================================

target game

    type        static
    root        source/game
    folder      04_GAME
    unit        game.c

# ==============================================================================

target nav

    type        static
    root        source/game_service/nav
    folder      04_GAME/SERVICE
    unit        nav.c

target game_example

    type        dynamic
    root        source/game_modules/game_example
    folder      04_GAME/MODULES
    unit        game_example.c

# ==============================================================================
# 05_Editor
# ==============================================================================

target 	editor

    type        static
    root        source/editor
    folder      05_Editor
    unit        editor.c

# ==============================================================================

target 	editor_viewport

    type        static
    root        source/editor_service/viewport
    folder      05_EDITOR/SERVICE
    unit        viewport.c

target 	editor_example

    type        dynamic
    root        source/editor_modules/editor_example
    folder      05_EDITOR/MODULES
    unit        editor_example.c

# ==============================================================================
# 06_Project
# ==============================================================================

target sample_game 

    type        static
    root        source/project/sample_game
    folder      06_Project
    unit        sample_game.c

# ==============================================================================
# 07_Developer
# ==============================================================================

target dev_build

    type        static
    root        source/developer/dev_build
    folder      07_Developer
    unit        dev_build.c
    dep         sys

target dev_hot

    type        static
    root        source/developer/dev_hot
    folder      07_Developer
    unit        dev_hot.c
    dep         sys
    dep         dev_build

# ==============================================================================
# 08_Host : Shared Host Executable Libraries
# ==============================================================================

target host_common

    type        static
    root        source/host/common
    folder      08_Host
    unit        host_common.c

target host_game

    type        static
    root        source/host/game
    folder      08_Host
    unit        host_game_main.c

target host_editor

    type        static
    root        source/host/editor
    folder      08_Host
    unit        host_editor_main.c
	
target host_tool

    type        static
    root        source/host/tool
    folder      08_Host
    unit        host_tool_main.c
	dep 		mod
	mono_dep	render

target host_sandbox

    type        static
    root        source/host/sandbox
    folder      08_Host
    unit        host_sandbox_main.c
	
# ==============================================================================
# 09_SANDBOX -- BASE
# ==============================================================================
	
target sb_base

    type        exe
    root        source/sandbox/base
    folder      09_SANDBOX/BASE
    unit        sb_base.c
    dep         base

# ==============================================================================
# 09_SANDBOX -- ENGINE
# ==============================================================================

target sb_engine_mod

    type        exe
    root        source/sandbox/engine/engine_mod
    folder      09_SANDBOX/ENGINE
    unit        sb_engine_mod.c
    dep         sys mod ref
    dep         dev_build dev_hot
	mono_dep 	example 

target sb_engine_sys

    type        exe
    root        source/sandbox/engine/engine_sys
    folder      09_SANDBOX/ENGINE
    unit        sb_engine_sys.c
    dep         sys

target sb_engine_app

    type        exe
    root        source/sandbox/engine/engine_app
    folder      09_SANDBOX/ENGINE
    unit        sb_engine_app.c
    dep         sys mod app

target sb_engine_core

    type        exe
    root        source/sandbox/engine/engine_core
    folder      09_SANDBOX/ENGINE
    unit        sb_engine_core.c
    dep         core

# ==============================================================================
# 09_SANDBOX -- REFLECT
# ==============================================================================

target sb_reflect							# dll test code

    type        exe
    root        source/sandbox/reflect
    folder      09_SANDBOX/REFLECT
    unit        sb_reflect_unit.c
    dep         ref
	
target example_reflect						# a dll that has reflected types

    type        dynamic
    root        source/sandbox/reflect/example_reflect
    folder      09_SANDBOX/REFLECT
    unit        example_reflect.c
    flag        reflect
	
target example_gen							# REF_MODULE() usage

    type        dynamic
    root        source/sandbox/reflect/example_gen
    folder      09_SANDBOX/REFLECT
    unit        example_gen.c
    flag        reflect
	
target sb_runtime_reflect					# load a dll with reflected types

    type        exe
    root        source/sandbox/reflect/runtime_reflect
    folder      09_SANDBOX/REFLECT
    unit        sb_runtime_reflect.c
    dep         sys mod core ref
	mono_dep 	example_reflect

target sb_runtime_gen						# load a REF_MODULE() dll

    type        exe
    root        source/sandbox/reflect/runtime_gen
    folder      09_SANDBOX/REFLECT
    unit        sb_runtime_gen.c
    dep         sys ref mod core
	mono_dep 	example_gen
    flag        reflect

# ==============================================================================
# 09_SANDBOX -- Vulkan
# ==============================================================================

target sb_vulkan						# vulkan development and testing

    type        exe
    root        source/sandbox/vulkan
    folder      09_SANDBOX/VULKAN
    unit        sb_vulkan.c
    dep         sys ref mod core app
	dep 		run rhi
	mono_dep 	render
  # flag        reflect

# ==============================================================================
# 09_SANDBOX -- EXAMPLE EXECUTABLE PROJECT TYPES
# ==============================================================================

target sb_example_runtime

    type        exe
    root        source/sandbox/example/example_runtime
    folder      09_SANDBOX/EXAMPLE
    unit        example_runtime.c
	dep 		mod ref sys core app		# static engine
    dep         run rhi						# static runtime + services
	mono_dep	render example_reflect
		
target sb_example_tool

    type        exe
    root        source/sandbox/example/example_tool
    folder      09_SANDBOX/EXAMPLE
    unit        example_tool.c
	dep 		mod ref sys core app
    dep         run
	mono_dep	render rhi

target sb_example_server

    type        exe
    root        source/sandbox/example/example_server
    folder      09_SANDBOX/EXAMPLE
    unit        example_server.c
	dep 		mod ref sys core app
    dep         run
	mono_dep	render rhi example

target sb_example_editor

    type        exe
    root        source/sandbox/example/example_editor
    folder      09_SANDBOX/EXAMPLE
    unit        example_editor.c
	dep 		mod ref sys core app
    dep         run rhi
	mono_dep	render example

target sb_example_game

    type        exe
    root        source/sandbox/example/example_game
    folder      09_SANDBOX/EXAMPLE
    unit        example_game.c
	dep 		mod ref sys core app
    dep         run rhi
	mono_dep	render		

# ==============================================================================
# DEV : Development Solution Wihout Any Sandbox or Test Code
# ==============================================================================

solution orb_dev

    out         build/proj
# 	nav 		source

	# 			--- STANDARD LIBRARY --- 
	add 		base

	# 			--- ENGINE --- 
    add         sys ref mod app core net
	
	# 			--- RUNTIME --- 
    add         run

	# 			--- RUNTIME SERVICES --- 
    add         rhi jobs
	
	# 			--- RUNTIME MODULES --- 
    add         render audio physics

	# 			--- RUNTIME MODULES -- examples --- 
    add         example example_reflect example_gen
	
	# 			--- GAME SERVICES --- 
    add         game 
	add 		nav 
	
	# 			--- GAME MODULES --- 
	add 		game_example

	# 			--- PROJECT --- 
	add 		sample_game

	# 			--- DEVELOPER --- 
    add         dev_build dev_hot
	
	# 			--- HOSTS -- 
    add         host_common

# ==============================================================================
# EDITOR : Editor development
# ==============================================================================

solution orb_editor 

    out         build/proj
	add 		editor
	add 		editor_viewport
	add 		editor_example

# ==============================================================================
# EXAMPLES: Executable Examples
# ==============================================================================

solution orb_examples	

    out         build/proj  
	
	add 		sb_example_tool
	add 		sb_example_server			
	add 		sb_example_editor 
	add 		sb_example_game 
	add 		sb_example_runtime

	#			--- project tyypes by host types ---
	
	add 		host_game
	add 		host_editor 
	add 		host_sandbox 
	add 		host_tool

# ==============================================================================
# SANDBOX: Running/debugging unit-style tets for specific engine layer
# ==============================================================================	

solution orb_sandbox_reflect			# developing reflection

    out         build/proj
    startup     sb_runtime_gen

    add         base
	add         sys ref mod app core net

	add 		sb_reflect				# unit test reflection (hand rolled)
	
	add 		example_gen				# test reflected REF_MODULE
	add 		example_reflect			# test module with reflected types
	
	add 		sb_runtime_gen			# test loading REF_MODULE		
	add 		sb_runtime_reflect		# test reading reflected types

	add 		reflect_tool


solution orb_sandbox_vulkan				# developing rendering / vulkan

    out         build/proj
    startup     sb_runtime_gen

    add         base
	add         sys ref mod app core net

	add 		run
	add 		rhi						# vulkan render library
	
	add 		sb_vulkan				# exe 


solution orb_sandbox_engine				# developing engine libraries

    out         build/proj
    startup     sb_runtime_gen

	add         sys ref mod app core net

	# 			--- SANDBOX : BASE -- 

    add         sb_base	
    add         sb_engine_mod 
	add 		sb_engine_sys 
	add 		sb_engine_core 
	add 		sb_engine_app
	
	# TOOD: engine test

# ==============================================================================
# TOOLS: TOOL DEVELOPMENT
# ==============================================================================

solution orb_build

    out         build/proj
    add         build_tool 
	add 		reflect_tool

# ==============================================================================
# FULL SOLUTION
# ==============================================================================

solution orb_all

    out         build/proj
# 	nav 		source

	add 		base
    add         sys ref mod app core net
	
    add         run	
    add         rhi jobs	
    add         render audio physics
	
    add         example example_reflect example_gen
    add         game nav game_example
    add         dev_build dev_hot
	
    add         host_common
	
	add         sb_engine_mod 
	add 		sb_engine_sys 
	add 		sb_engine_core 

	add 		sb_engine_app
	
	# 			reflection testing
	add 		sb_reflect sb_runtime_reflect sb_runtime_gen
	
	add 		host_game
	add 		host_editor 
	add 		host_sandbox 
	add 		host_tool
	
	add 		sb_example_tool
	add 		sb_example_server			
	add 		sb_example_editor 
	add 		sb_example_game 
	add 		sb_example_runtime
	
	
# ==============================================================================
# FULL SOLUTION : MONOLITHIC
# ==============================================================================

solution orb_all_mono

    out         build/proj_mono
    flag        monolithic
    add         orb_all

# =============================================================================