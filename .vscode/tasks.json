{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "orb: build debug",
      "type": "process",
      "command": "${workspaceFolder}\\bin\\build_tool.exe",
      "args": ["-config", "Debug"],
      "group": { "kind": "build", "isDefault": true },
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "orb: build release",
      "type": "process",
      "command": "${workspaceFolder}\\bin\\build_tool.exe",
      "args": ["-config", "Release"],
      "group": "build",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "orb: build target",
      "type": "process",
      "command": "${workspaceFolder}\\bin\\build_tool.exe",
      "args": ["-config", "Debug", "-target", "${input:targetName}"],
      "group": "build",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "orb: clean",
      "type": "process",
      "command": "${workspaceFolder}\\bin\\build_tool.exe",
      "args": ["-clean"],
      "group": "build",
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "orb: regen",
      "type": "process",
      "command": "${workspaceFolder}\\bin\\build_tool.exe",
      "args": ["-gen"],
      "group": "build",
      "options": { "cwd": "${workspaceFolder}" }
    }
  ],
  "inputs": [
    {
      "id": "targetName",
      "type": "pickString",
      "description": "Select target",
      "options": [
        "build_tool",
        "reflect_tool",
        "base",
        "sys",
        "rs",
        "mod",
        "app",
        "core",
        "runtime_host",
        "rhi",
        "jobs",
        "example",
        "render",
        "audio",
        "physics",
        "example_reflect",
        "example_gen",
        "game",
        "nav",
        "game_example",
        "dev_build",
        "dev_hot",
        "host_common",
        "sb_engine_mod",
        "sb_engine_sys",
        "sb_engine_app",
        "sb_engine_core",
        "sb_engine_reflect",
        "sb_runtime_reflect",
        "sb_runtime_gen",
        "sb_base_main",
        "c11_test"
      ]
    }
  ]
}
